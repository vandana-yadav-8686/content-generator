# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
DATA_DIR=./data
# Comma-separated allowed frontend origins (required in production)
# Example: http://localhost:3000,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# MongoDB Atlas (required — provider settings + generated content)
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=content_repurposing

# Optional OpenAI fallback if no provider enabled in Settings
OPENAI_API_KEY=
